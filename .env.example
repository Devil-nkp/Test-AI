# ══════════════════════════════════════════════════
# PrepVista AI — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════

# ── App ──────────────────────────────────────────
APP_NAME="PrepVista AI"
DEBUG=true
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Supabase ─────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
DATABASE_URL=postgresql://postgres:your_password@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Stripe ───────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_CAREER_PRICE_ID=price_your_career_price_id

# ── LLM Providers ────────────────────────────────
# Groq: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EVAL_MODEL=llama-3.3-70b-versatile

# OpenAI (fallback): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ── Upstash Redis (Rate Limiting) ────────────────
# Get these from: https://console.upstash.com/
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token

# ── Resend (Email) ───────────────────────────────
# RESEND_API_KEY=re_your_resend_key
# FROM_EMAIL=PrepVista AI <noreply@prepvista.ai>
